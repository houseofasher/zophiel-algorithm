    "build": "tsc",
    "start": "node dist/main.js",
    "start:sovereign": "node dist/sovereign_main.js",
    "test": "npm run build && node dist/tests/run_all.js",
    "test:protocol": "npm run build && node dist/tests/protocol.test.js",
    "test:fuzz": "npm run build && node dist/tests/fuzz.test.js",
    "test:audit": "npm run build && node dist/tests/dependency_audit.test.js",
    "test:battle": "npm run build && node dist/tests/battle.test.js",
    "sidecar": "npm run build && node dist/sidecar_main.js",
    "verify:deps": "npm run build && node dist/startup/verify_deps.js",
    "generate:sbom": "npm run build && node dist/scripts/generate_sbom.js",
    "key:ceremony": "npm run build && node dist/scripts/key_ceremony.js"
